{
  "agents": {
    "defaults": {
      "model": "openai/gpt-5.4-mini",
      "workspace": ".",
      "subagents": {
        "maxSpawnDepth": 1,
        "maxConcurrent": 8,
        "maxChildrenPerAgent": 5,
        "model": "google/gemini-3-flash-preview",
        "runTimeoutSeconds": 300
      }
    },
    "list": [
      {
        "id": "orchestrator",
        "default": true,
        "tools": {
          "profile": "full",
          "deny": ["browser", "canvas", "nodes", "image", "pdf", "tts"]
        },
        "subagents": {
          "allowAgents": ["*"]
        }
      }
    ]
  },
  "tools": {
    "profile": "coding",
    "allow": ["browser", "exec", "file_read", "file_write"]
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": []
    }
  },
  "browser": {
    "headless": true,
    "timeout": 60
  }
}
